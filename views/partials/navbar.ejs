<nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary px-3">
  <a class="navbar-brand fw-bold fs-5" href="/dashboard">
    <i class="bi bi-robot text-primary me-2"></i>Axobotl
  </a>
  <div class="ms-auto d-flex align-items-center gap-3">
    <% if (user) { %>
      <span class="text-muted small d-none d-md-inline"><%= user.username %></span>
      <img
        src="<%= user.avatar
          ? `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png?size=32`
          : `https://cdn.discordapp.com/embed/avatars/${parseInt(user.discriminator ?? '0') % 5}.png`
        %>"
        class="rounded-circle"
        width="32" height="32" alt="Avatar">
      <form action="/auth/logout" method="post" class="m-0">
        <button type="submit" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-box-arrow-right"></i>
        </button>
      </form>
    <% } %>
  </div>
</nav>
