<%- include('partials/app-html') %>

<head>
    <%- include('partials/app-meta-title', { pageTitle: title ?? 'Error' }) %>
    <%- include('partials/app-head-css') %>
</head>

<body>

    <div class="min-vh-100 d-flex align-items-center justify-content-center">
        <div class="text-center p-5">
            <div class="mb-4">
                <svg class="sa-icon sa-icon-5x text-danger">
                    <use href="/icons/sprite.svg#alert-triangle"></use>
                </svg>
            </div>
            <h1 class="fw-bold mb-2"><%= title ?? 'Error' %></h1>
            <p class="text-muted fs-lg mb-4"><%= message ?? 'Something went wrong.' %></p>
            <a href="/dashboard" class="btn btn-primary">
                <svg class="sa-icon me-1">
                    <use href="/icons/sprite.svg#arrow-left"></use>
                </svg>
                Back to Dashboard
            </a>
        </div>
    </div>

    <script src="/plugins/bootstrap/bootstrap.bundle.min.js"></script>

</body>

</html>