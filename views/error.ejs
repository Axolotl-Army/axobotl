<%- include('partials/head', { title: title ?? 'Error' }) %>

<div class="min-vh-100 d-flex align-items-center justify-content-center bg-dark">
  <div class="text-center">
    <i class="bi bi-exclamation-octagon text-danger" style="font-size: 4rem;"></i>
    <h2 class="mt-3 fw-bold"><%= title ?? 'Error' %></h2>
