<%- include('../partials/head', { title: 'Logs' }) %>
<%- include('../partials/navbar') %>

<div class="container-fluid">
  <div class="row">
    <%- include('../partials/sidebar', { activePage: 'logs' }) %>

    <main class="col-md-10 ms-sm-auto px-md-4 py-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">Command Logs</h4>
        <span class="text-muted small"><%= pagination.totalEntries.toLocaleString() %> total entries</span>
      </div>

      <div class="card bg-dark border-secondary">
        <div class="card-body p-0">
          <% if (logs.length === 0) { %>
            <p class="text-muted text-center py-4 mb-0">No logs yet.</p>
          <% } else { %>
            <div class="table-responsive">
              <table class="table table-dark table-hover mb-0">
                <thead>
                  <tr class="text-muted small">
                    <th>Command</th>
                    <th>User</th>
                    <th>Guild ID</th>
                    <th>Status</th>
                    <th>Time</th>
                  </tr>
                </thead>
                <tbody>
                  <% logs.forEach(log => { %>
                    <tr>
                      <td><code>/<%= log.command %></code></td>
                      <td class="small"><%= log.username %></td>
                      <td class="text-muted small"><%= log.guildId %></td>
                      <td>
                        <span class="badge bg-<%= log.successful ? 'success' : 'danger' %>">
                          <%= log.successful ? 'OK' : 'Error' %>
                        </span>
                      </td>
                      <td class="text-muted small"><%= new Date(log.createdAt).toLocaleString() %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Pagination -->
      <% if (pagination.total > 1) { %>
        <nav class="mt-3">
          <ul class="pagination pagination-sm justify-content-center">
            <% for (let i = 1; i <= pagination.total; i++) { %>
              <li class="page-item <%= i === pagination.current ? 'active' : '' %>">
                <a class="page-link" href="/dashboard/logs?page=<%= i %>"><%= i %></a>
              </li>
            <% } %>
          </ul>
        </nav>
      <% } %>
    </main>
  </div>
</div>

<%- include('../partials/scripts') %>
