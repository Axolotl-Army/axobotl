<%- include('../partials/head', { title: 'Commands' }) %>
<%- include('../partials/navbar') %>

<div class="container-fluid">
  <div class="row">
    <%- include('../partials/sidebar', { activePage: 'commands' }) %>

    <main class="col-md-10 ms-sm-auto px-md-4 py-4">
      <h4 class="fw-bold mb-4">Command Usage</h4>

      <div class="card bg-dark border-secondary">
        <div class="card-body p-0">
          <% if (commandStats.length === 0) { %>
            <p class="text-muted text-center py-4 mb-0">No command data available yet.</p>
          <% } else { %>
            <div class="table-responsive">
              <table class="table table-dark table-hover mb-0">
                <thead>
                  <tr class="text-muted small">
                    <th>Command</th>
                    <th>Total Uses</th>
                    <th>Last Used</th>
                  </tr>
                </thead>
                <tbody>
                  <% commandStats.forEach(stat => { %>
                    <tr>
                      <td><code>/<%= stat.command %></code></td>
                      <td><%= parseInt(stat.count).toLocaleString() %></td>
                      <td class="text-muted small">
                        <%= stat.last_used ? new Date(stat.last_used).toLocaleString() : 'Never' %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('../partials/scripts') %>
