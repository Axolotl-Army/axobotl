<%- include('../partials/app-html') %>

<head>
    <%- include('../partials/app-meta-title') %>
    <%- include('../partials/app-head-css') %>
</head>

<body>

    <div class="app-wrap">

        <%- include('../partials/app-header') %>

        <%- include('../partials/app-sidebar') %>

        <main class="app-body">
            <div class="app-content">

                <div class="content-wrapper">

                    <%- include('../partials/app-pagetitle') %>

                    <div class="main-content">

                        <div class="card shadow-0 mb-g">
                            <div class="card-header">
                                <div class="card-title">Command Usage</div>
                            </div>
                            <div class="card-body p-0">
                                <% if (commandStats.length === 0) { %>
                                    <p class="text-muted text-center py-4 mb-0">No command data available yet.</p>
                                <% } else { %>
                                    <div class="table-responsive">
                                        <table class="table table-hover mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Command</th>
                                                    <th>Total Uses</th>
                                                    <th>Last Used</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% commandStats.forEach(stat => { %>
                                                    <tr>
                                                        <td><code>/<%= stat.command %></code></td>
                                                        <td><%= parseInt(stat.count).toLocaleString() %></td>
                                                        <td class="text-muted small">
                                                            <%= stat.last_used ? new Date(stat.last_used).toLocaleString() : 'Never' %>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            </tbody>
                                        </table>
                                    </div>
                                <% } %>
                            </div>
                        </div>

                    </div>
                </div>

            </div>

            <%- include('../partials/app-footer') %>

        </main>

        <%- include('../partials/app-drawer') %>

        <%- include('../partials/app-settings') %>

    </div>

    <%- include('../partials/app-scripts') %>

</body>

</html>