<%- include('../partials/app-html') %>

<head>
    <%- include('../partials/app-meta-title') %>
    <%- include('../partials/app-head-css') %>
</head>

<body>

    <div class="app-wrap">

        <%- include('../partials/app-header') %>

        <%- include('../partials/app-sidebar') %>

        <main class="app-body">
            <div class="app-content">

                <div class="content-wrapper">

                    <%- include('../partials/app-pagetitle') %>

                    <div class="main-content">

                        <!-- Stats cards -->
                        <div class="row g-3 mb-4">
                            <div class="col-sm-6 col-lg-3">
                                <div class="card shadow-0 mb-0">
                                    <div class="card-body d-flex align-items-center gap-3">
                                        <div class="p-2 bg-primary bg-opacity-25 rounded">
                                            <svg class="sa-icon sa-icon-2x text-primary">
                                                <use href="/icons/sprite.svg#server"></use>
                                            </svg>
                                        </div>
                                        <div>
                                            <div class="text-muted small">Guilds</div>
                                            <div class="fs-4 fw-bold"><%= stats.guildCount.toLocaleString() %></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6 col-lg-3">
                                <div class="card shadow-0 mb-0">
                                    <div class="card-body d-flex align-items-center gap-3">
                                        <div class="p-2 bg-success bg-opacity-25 rounded">
                                            <svg class="sa-icon sa-icon-2x text-success">
                                                <use href="/icons/sprite.svg#terminal"></use>
                                            </svg>
                                        </div>
                                        <div>
                                            <div class="text-muted small">Commands Executed</div>
                                            <div class="fs-4 fw-bold"><%= stats.totalCommands.toLocaleString() %></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Recent activity -->
                        <div class="card shadow-0 mb-g">
                            <div class="card-header d-flex align-items-center justify-content-between">
                                <div class="card-title">Recent Commands</div>
                                <a href="/dashboard/logs" class="btn btn-sm btn-outline-secondary">View all</a>
                            </div>
                            <div class="card-body p-0">
                                <% if (recentLogs.length === 0) { %>
                                    <p class="text-muted text-center py-4 mb-0">No commands logged yet.</p>
                                <% } else { %>
                                    <div class="table-responsive">
                                        <table class="table table-hover mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Command</th>
                                                    <th>User</th>
                                                    <th>Status</th>
                                                    <th>Time</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% recentLogs.forEach(log => { %>
                                                    <tr>
                                                        <td><code>/<%= log.command %></code></td>
                                                        <td class="text-muted small"><%= log.username %></td>
                                                        <td>
                                                            <% if (log.successful) { %>
                                                                <span class="badge bg-success">OK</span>
                                                            <% } else { %>
                                                                <span class="badge bg-danger">Error</span>
                                                            <% } %>
                                                        </td>
                                                        <td class="text-muted small"><%= new Date(log.createdAt).toLocaleString() %></td>
                                                    </tr>
                                                <% }) %>
                                            </tbody>
                                        </table>
                                    </div>
                                <% } %>
                            </div>
                        </div>

                    </div>
                </div>

            </div>

            <%- include('../partials/app-footer') %>

        </main>

        <%- include('../partials/app-drawer') %>

        <%- include('../partials/app-settings') %>

    </div>

    <%- include('../partials/app-scripts') %>

</body>

</html>