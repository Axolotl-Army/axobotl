# ============================================================
# Axobotl Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ----- Discord Bot -----
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret

# Discord user ID of the bot owner (for admin dashboard access)
BOT_OWNER_ID=your_discord_user_id

# ----- Database (PostgreSQL) -----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/axobotl
# OR use individual fields (DATABASE_URL takes precedence if set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=axobotl
DB_USER=postgres
DB_PASSWORD=postgres

# ----- Dashboard -----
DASHBOARD_PORT=3000
# Long random string — generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_a_long_random_secret

# Public URL of your dashboard (used in OAuth callback)
DASHBOARD_URL=http://localhost:3000
DISCORD_CALLBACK_URL=http://localhost:3000/auth/callback

# ----- Docker / GHCR -----
# Your GitHub username or organization (owner of the repository)
# Used to pull images: ghcr.io/<GHCR_OWNER>/axobotl-bot
GHCR_OWNER=your_github_username_or_org

# ----- Environment -----
NODE_ENV=development
