{
  "name": "axobotl",
  "version": "0.1.0",
  "description": "Discord bot with web dashboard — discord.js, Sequelize, PostgreSQL, Next.js, SmartAdmin",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:bot\" \"pnpm dev:dashboard\"",
    "dev:bot": "tsx watch src/bot/index.ts",
    "dev:dashboard": "cd src/dashboard && pnpm exec next dev -p 3000",
    "dev:test:website": "cd src/dashboard && pnpm exec next dev -p 4000",
    "build": "tsc && cd src/dashboard && next build",
    "start": "concurrently \"pnpm start:bot\" \"pnpm start:dashboard\"",
    "start:bot": "node dist/bot/index.js",
    "start:dashboard": "cd src/dashboard && pnpm exec next start -p 3000",
    "typecheck": "tsc --noEmit",
    "typecheck:dashboard": "cd src/dashboard && pnpm exec tsc --noEmit",
    "deploy-commands": "tsx scripts/deploy-commands.ts",
    "db:sync": "tsx scripts/db-sync.ts",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm test:kill-ports && playwright test",
    "test:e2e:ui": "pnpm test:kill-ports && playwright test --ui",
    "test:e2e:headed": "pnpm test:kill-ports && playwright test --headed",
    "test:e2e:chromium": "pnpm test:kill-ports && playwright test --project=chromium",
    "test:e2e:report": "playwright show-report",
    "test:kill-ports": "lsof -ti:4000,4010,4020 | xargs kill -9 2>/dev/null || true"
  },
  "dependencies": {
    "concurrently": "^9.1.0",
    "discord.js": "^14.16.3",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=6.23.0",
      "esbuild": ">=0.25.0"
    }
  }
}
