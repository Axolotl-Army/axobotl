{
  "name": "axobotl",
  "version": "0.1.0",
  "description": "Discord bot with web dashboard — discord.js, Sequelize, PostgreSQL, Bootstrap 5",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:bot\" \"pnpm dev:dashboard\"",
    "dev:bot": "tsx watch src/bot/index.ts",
    "dev:dashboard": "tsx watch src/dashboard/index.ts",
    "dev:test:website": "PORT=4000 tsx watch src/dashboard/index.ts",
    "build": "tsc",
    "start": "concurrently \"pnpm start:bot\" \"pnpm start:dashboard\"",
    "start:bot": "node dist/bot/index.js",
    "start:dashboard": "node dist/dashboard/index.js",
    "typecheck": "tsc --noEmit",
    "deploy-commands": "tsx scripts/deploy-commands.ts",
    "db:sync": "tsx scripts/db-sync.ts",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm test:kill-ports && playwright test",
    "test:e2e:ui": "pnpm test:kill-ports && playwright test --ui",
    "test:e2e:headed": "pnpm test:kill-ports && playwright test --headed",
    "test:e2e:chromium": "pnpm test:kill-ports && playwright test --project=chromium",
    "test:e2e:report": "playwright show-report",
    "test:kill-ports": "lsof -ti:4000,4010,4020 | xargs kill -9 2>/dev/null || true"
  },
  "dependencies": {
    "concurrently": "^9.1.0",
    "connect-pg-simple": "^10.0.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.1",
    "express-session": "^1.18.1",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.9.0",
    "@types/passport": "^1.0.16",
    "@types/passport-discord": "^0.1.15",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=6.23.0",
      "esbuild": ">=0.25.0"
    }
  }
}
